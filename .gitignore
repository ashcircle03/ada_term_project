# 제출 ZIP 제외 경로
archive/
AGENTS.md
REPORT.md
REPORT*.txt

# dot-prefixed 로컬 경로
.*
!.gitignore

# 환경
.conda/
__pycache__/
*.pyc
.DS_Store

*.key

# data/ 경로는 README만 제출 ZIP에 포함하고, 원자료·캐시는 제외
data/*
!data/README.md

# 크롤링 raw HTML (336MB, 너무 큼)
data/raw_html/

# 캐시 (재생성 가능)
data/cache/
.cache/

# 로그
logs/

# Jupyter
.ipynb_checkpoints/

# Office 임시 잠금 파일
~$*.docx

# DB (190MB+, 크롤할 때마다 변경 → git 추적 제외. 로컬 보존/재크롤로 충분)
data/fruitsfamily.db
data/fruitsfamily.db-wal
data/fruitsfamily.db-shm
